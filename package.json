{
  "name": "plain-dictionary",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "dictionary:build": "node scripts/build-dictionary.mjs",
    "dictionary:release": "node scripts/create-dictionary-release.mjs",
