  },
  "dependencies": {
    "@tauri-apps/api": "^2.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.5.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^29.1.1",
    "node-html-parser": "^8.0.1",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.9"
  }
